# Template for the secrets docker-compose needs. Copy to `.env` and fill real values.
# `.env` is gitignored; this .example file is safe to commit.
#
# Brevo SMTP: get these from Brevo → Transactional → Email → SMTP & API.
#   - EMAIL_USER is Brevo's dedicated SMTP "Login" (looks like bXXXXXX@smtp-brevo.com),
#     NOT your Brevo account email.
#   - EMAIL_PASSWORD is an SMTP key (generated once; not your account password).
#   - EMAIL_FROM must be a VERIFIED sender in Brevo → Senders.
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USER=bXXXXXX@smtp-brevo.com
EMAIL_PASSWORD=your-brevo-smtp-key
EMAIL_FROM=your-verified-sender@example.com
EMAIL_FROM_NAME=ShadowBoard Tracker
EMAIL_STARTTLS=true
